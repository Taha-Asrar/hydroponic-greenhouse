# ============================================================
# Serre Hydroponique — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/serre_hydroponique

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-secret-key

# --- JWT ---
JWT_SECRET_KEY=change-this-to-another-random-secret-key
JWT_ACCESS_TOKEN_EXPIRES=3600

# --- Port série Arduino ---
SERIAL_PORT=COM3
SERIAL_BAUDRATE=9600

# --- Notifications Email (bonus) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=

# --- Serveur ---
HOST=0.0.0.0
PORT=5000
